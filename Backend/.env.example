# Copy to .env for local dev. On Vercel, add these under
# Project Settings -> Environment Variables.

# Server (Vercel sets PORT automatically; only needed locally)
PORT=5000

# AI providers
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_SENDER_ADDRESS=
EMAIL_SENDER_NAME=

# n8n webhook
N8N_WEBHOOK_URL=
